{
    "layer": "top",
    "position": "top",
    "height": 34,
    "margin-top": 3,
    "margin-left": 3,
    "margin-right": 3,
    "margin-bottom": 0,
    "spacing": 4,
    "modules-left": ["sway/workspaces", "sway/mode", "sway/window"],
    "modules-center": ["clock"],
    "modules-right": ["custom/recorder", "custom/clipse", "custom/capslock", "custom/autosleep", "tray", "custom/swaync", "group/hardware", "custom/power"],

    "group/hardware": {
        "orientation": "horizontal",
        "modules": ["pulseaudio", "backlight", "custom/battery"]
    },

    "tray": {
        "spacing": 10
    },

    "sway/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "format": "{name}"
    },
    "sway/window": {
        "max-length": 40
    },
    "clock": {
        "format": "<span color='#bb9af7'>ůį•Ē</span>  {:%I:%M %p   <span color='#7aa2f7'>ůįÉ≠</span>  %b %e}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "custom/battery": {
        "exec": "~/.config/waybar/battery.sh",
        "on-click": "~/.config/waybar/tlp_menu.sh",
        "return-type": "json",
        "format": "<span color='#bb9af7'>{alt}</span> {text}"
    },
    "custom/clipse": {
        "exec": "echo '{\"text\": \"ůįÖĆ\", \"tooltip\": \"Clipboard Manager\"}'",
        "return-type": "json",
        "interval": "once",
        "format": "<span color='#bb9af7'> {text} </span>",
        "on-click": "~/.config/sway/clipse-toggle.sh"
    },
    "network": {
        "format-wifi": "<span color='#7dcfff'>ůį§®</span>   {essid}",
        "format-ethernet": "<span color='#7dcfff'>ůįąÄ</span>   {ipaddr}/{cidr}",
        "tooltip-format": "{ifname} via {gwaddr} ůįäó",
        "format-linked": "{ifname} (No IP) ůįąÄ",
        "format-disconnected": "<span color='#F7768E'>ůį§≠</span>   Disconnected",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        "tooltip": true,
        "tooltip-format": "Scroll: Adjust Volume\nLeft Click: Pavucontrol\nMiddle Click: Mute/Unmute",
        "format": "<span color='#7aa2f7'>{icon}</span> ‚ÄČ‚Ää{volume}%",
        "format-bluetooth": "<span color='#7aa2f7'>{icon}ůįāį</span> ‚ÄČ‚Ää{volume}%",
        "format-bluetooth-muted": "<span color='#F7768E'>ůįĖĀůįāį</span>",
        "format-muted": "<span color='#F7768E'>ůįĖĀ</span> ‚ÄČ‚ÄäMuted",
        "format-icons": {
            "headphone": "ůįčč",
            "hands-free": "ůįčč",
            "headset": "ůįčč",
            "phone": "Ôāē",
            "portable": "Ôāē",
            "car": "ÔÜĻ",
            "default": ["ůįēŅ", "ůįĖÄ", "ůįēĺ"]
        },
        "on-click": "~/.config/waybar/pavu_toggle.sh",
        "on-click-middle": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
    },
    "backlight": {
        "tooltip": true,
        "tooltip-format": "Scroll: Adjust Brightness\nMiddle Click: Toggle Caffeine Mode",
        "format": "<span color='#e0af68'>{icon}</span> ‚ÄČ‚Ää{percent}%",
        "format-icons": ["ůįÉě", "ůįÉü", "ůįÉ†"],
        "on-click-middle": "~/.config/waybar/toggle_idle.sh",
        "on-scroll-up": "brightnessctl set 1%+",
        "on-scroll-down": "brightnessctl set 1%-"
    },
    "bluetooth": {
        "format": "<span color='#bb9af7'>ůįāĮ</span>  {status}",
        "format-disabled": "<span color='#F7768E'>ůįā≤</span>  Disabled",
        "format-connected": "<span color='#bb9af7'>ůįāĪ</span>  {num_connections}",
        "tooltip-format": "{controller_alias}\t{controller_address}",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "on-click": "pkill blueman-manager || blueman-manager"
    },
    "custom/swaync": {
        "tooltip": true,
        "format": "<span color='#bb9af7'> {icon} </span>",
        "format-icons": {
            "notification": "ůĪÖę",
            "none": "ůįāö",
            "dnd-notification": "ůĪŹß",
            "dnd-none": "ůĪŹß",
            "inhibited-notification": "ůĪÖę",
            "inhibited-none": "ůįāö",
            "dnd-inhibited-notification": "ůĪŹß",
            "dnd-inhibited-none": "ůĪŹß"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "on-click-middle": "swaync-client -d -sw",
        "escape": true
    },
    "custom/power": {
        "format": " ÔÄĎ ",
        "tooltip": true,
        "on-click": "~/.config/rofi/powermenu.sh",
        "return-type": "json",
        "exec": "echo '{\"tooltip\": \"Power Menu\"}'",
        "interval": "once"
    },
    "custom/recorder": {
        "exec": "~/.config/waybar/recorder.sh",
        "return-type": "json",
        "format": "{text}",
        "on-click": "~/.config/sway/toggle_recorder.sh"
    },
    "custom/autosleep": {
        "exec-if": "test -f ~/.config/sway/.autosleep_disabled",
        "exec": "echo '{\"text\": \"ůįÖ∂\", \"tooltip\": \"Autosleep is OFF (Caffeine Mode)\\n\\nLeft Click: Enable Autosleep\"}'",
        "return-type": "json",
        "interval": 86400,
        "signal": 10,
        "format": "<span color='#e0af68'> {text} </span>",
        "on-click": "~/.config/waybar/toggle_idle.sh"
    },
    "custom/capslock": {
        "exec": "~/.config/waybar/capslock.sh",
        "return-type": "json",
        "format": "{text}"
    }
}
