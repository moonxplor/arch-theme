@import "config.rasi"

window {
    width: 220px;
    location: northeast;
    anchor: northeast;
    x-offset: -8px;
    y-offset: 23px;
    border-radius: 12px;
}

inputbar {
    enabled: false;
}

listview {
    lines: 5;
    padding: 5px;
}

element {
    padding: 10px 15px;
}

element-text {
    font: "JetBrainsMono Nerd Font 13";
}
